{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"vcs": {
		"enabled": false
	},
	"files": {
		"includes": [
			"src/**/*.ts",
			"src/**/*.mts",
			"src/**/*.cts",
			"scripts/**/*.ts",
			"examples/**/*.ts",
			"test/**/*.ts"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
